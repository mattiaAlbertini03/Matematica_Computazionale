Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Variabili", " ", "globali", " ", "per", " ", 
    RowBox[{"l", "'"}], "immagine"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"defImg", "=", 
     RowBox[{
     "Import", 
      "[", "\"\<https://c8.alamy.com/compit/j253d8/esempio-illustrativo-del-\
timbro-j253d8.jpg\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"img", " ", "=", " ", "defImg"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"blur", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"colore", " ", "=", " ", "None"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rotazione", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"translaX", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"translaY", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Definizione", " ", "del", " ", "bottone", " ", "per", " ", "caricare", " ",
      "un", " ", "immagine", " ", "in", " ", "img"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bottoneCaricamento", " ", "=", " ", 
     RowBox[{"DynamicModule", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Button", "[", 
        RowBox[{"\"\<Carica Immagine\>\"", ",", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "Apre", " ", "il", " ", "selettore", " ", "file", " ", "e", " ", 
           "importa", " ", "se", " ", 
           RowBox[{"l", "'"}], "utente", " ", "non", " ", "annulla"}], "*)"}],
          "\[IndentingNewLine]", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"file", "=", 
             RowBox[{"SystemDialogInput", "[", "\"\<FileOpen\>\"", "]"}]}], 
            "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"file", "=!=", "$Canceled"}], ",", 
             RowBox[{"img", "=", 
              RowBox[{"Import", "[", "file", "]"}]}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Method", "->", "\"\<Queued\>\""}]}], " ", 
        RowBox[{"(*", 
         RowBox[{
         "Importante", " ", "per", " ", "evitare", " ", "timeout", " ", "con",
           " ", "file", " ", "grandi"}], "*)"}], "\[IndentingNewLine]", 
        "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bottonePulisci", " ", "=", " ", 
     RowBox[{"DynamicModule", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Button", "[", 
        RowBox[{"\"\<Pulisci\>\"", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"blur", "=", "0"}], ";", "\[IndentingNewLine]", 
          RowBox[{"rotazione", "=", "0"}], ";", "\[IndentingNewLine]", 
          RowBox[{"translaX", "=", "0"}], ";", "\[IndentingNewLine]", 
          "translaY", ";", "\[IndentingNewLine]", 
          RowBox[{"colore", " ", "=", " ", "None"}], ";"}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mostraImmagine", "=", " ", 
     RowBox[{"DynamicModule", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Dynamic", "[", 
        RowBox[{"Show", "[", "img", "]"}], "]"}]}], "\[IndentingNewLine]", 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"controlloBlur", " ", "=", 
     RowBox[{"\"\<Blur\>\"", "->", 
      RowBox[{"Slider", "[", 
       RowBox[{
        RowBox[{"Dynamic", "[", "blur", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "100", ",", " ", "1"}], "}"}], ",", 
        RowBox[{"Appearance", "->", "\"\<Labeled\>\""}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"controlloColore", " ", "=", " ", 
     RowBox[{"\"\<Scala Colore\>\"", "->", 
      RowBox[{"ColorSetter", "[", 
       RowBox[{
        RowBox[{"Dynamic", "[", "colore", "]"}], ",", 
        RowBox[{"Appearance", "->", "\"\<Labeled\>\""}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"controlloRotazione", " ", "=", " ", 
     RowBox[{"\"\<Rotazione\>\"", "->", 
      RowBox[{"Slider", "[", 
       RowBox[{
        RowBox[{"Dynamic", "[", "rotazione", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "360", ",", " ", "30"}], "}"}], ",", 
        RowBox[{"Appearance", "->", "\"\<Labeled\>\""}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"controlloTranslazione", "=", " ", 
     RowBox[{"\"\<Translazione\>\"", "->", 
      RowBox[{"GraphicsColumn", "[", 
       RowBox[{
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Slider", "[", 
           RowBox[{
            RowBox[{"Dynamic", "[", "translaX", "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "1000", ",", "50"}], "}"}], ",", 
            RowBox[{"Appearance", "->", "\"\<Labeled\>\""}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Slider", "[", 
           RowBox[{
            RowBox[{"Dynamic", "[", "translaY", "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "1000", ",", " ", "50"}], "}"}], ",", 
            RowBox[{"Appearance", "->", "\"\<Labeled\>\""}]}], "]"}]}], 
         "\[IndentingNewLine]", "}"}], ",", " ", 
        RowBox[{"ImageSize", "->", "Medium"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"controlliImmagine", "=", 
     RowBox[{"DynamicModule", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", 
       RowBox[{"TabView", "[", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
         "controlloBlur", ",", "\[IndentingNewLine]", "controlloColore", ",", 
          "\[IndentingNewLine]", "controlloRotazione", ",", 
          "\[IndentingNewLine]", "controlloTranslazione"}], 
         "\[IndentingNewLine]", "}"}], "]"}], ",", 
       RowBox[{"ImageSize", "->", "Large"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Funzione", " ", "di", " ", "traslazione", " ", "con", " ", "wrap"}], "-",
      "around"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"translateImageWrap", "[", 
     RowBox[{"image_", ",", "tx_", ",", "ty_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"data", ",", "dims", ",", "w", ",", "h", ",", "shiftedData"}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"data", "=", 
        RowBox[{"ImageData", "[", "image", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dims", "=", 
        RowBox[{"Dimensions", "[", "data", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"h", "=", 
        RowBox[{"dims", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"w", "=", 
        RowBox[{"dims", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "Normalizza", " ", "gli", " ", "shift", " ", "con", " ", "Mod", " ", 
          "per", " ", "il", " ", "wrap"}], "-", "around"}], "*)"}], 
       RowBox[{"shiftedData", "=", 
        RowBox[{"RotateRight", "[", 
         RowBox[{"data", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"Round", "[", "ty", "]"}], ",", "h"}], "]"}], ",", 
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"Round", "[", "tx", "]"}], ",", "w"}], "]"}], ",", 
            "0"}], "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Image", "[", "shiftedData", "]"}]}]}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"colorizeImage", "[", 
     RowBox[{"image_", ",", "color_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"grayImg", ",", "hsvColor"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"color", "===", "None"}], ",", "\[IndentingNewLine]", "image",
         ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"hsvColor", "=", 
          RowBox[{"ColorConvert", "[", 
           RowBox[{"color", ",", "Hue"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Colorize", "[", 
          RowBox[{"image", ",", 
           RowBox[{"ColorFunction", "->", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Hue", "[", 
               RowBox[{
                RowBox[{"hsvColor", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], ",", 
                RowBox[{"hsvColor", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], ",", "#"}], "]"}], "&"}], 
             ")"}]}]}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"modifiedImg", "=", 
     RowBox[{"DynamicModule", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Dynamic", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"blurredImg", " ", "=", " ", 
          RowBox[{"Blur", "[", 
           RowBox[{"img", ",", " ", "blur"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"rotatedImg", " ", "=", " ", 
          RowBox[{"ImageRotate", "[", 
           RowBox[{"blurredImg", ",", " ", 
            RowBox[{"rotazione", "*", "Degree"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"translatedImg", " ", "=", " ", 
          RowBox[{"translateImageWrap", "[", 
           RowBox[{"rotatedImg", ",", " ", "translaX", ",", " ", "translaY"}],
            "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"colorizedImg", " ", "=", " ", 
          RowBox[{"colorizeImage", "[", 
           RowBox[{"img", ",", "colore"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Show", "[", "colorizedImg", "]"}]}], "\[IndentingNewLine]", 
        "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]",
    "\[IndentingNewLine]", "\n", 
   RowBox[{"Panel", "[", 
    RowBox[{"GraphicsRow", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"GraphicsColumn", "[", 
        RowBox[{
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{
