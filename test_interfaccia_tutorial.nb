           ",", "\[IndentingNewLine]", "modifiedImg"}], "\[IndentingNewLine]",
           "}"}], ",", " ", 
         RowBox[{"ImageSize", "->", "Medium"}]}], "]"}], ",", 
       "\[IndentingNewLine]", "controlliImmagine", ",", "\[IndentingNewLine]",
        "bottonePulisci"}], "\[IndentingNewLine]", "}"}], "]"}], "]"}], 
   "\[IndentingNewLine]"}]}]], "Input",
